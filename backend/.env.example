# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/momstalk_db
AUTH_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/momstalk_auth_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Anonymous Token (분리된 익명화용 키 - 서비스 DB와 인증 DB 연결 불가하게 분리)
ANON_HASH_SECRET=separate-secret-for-anonymous-hashing

# SMS 인증 (PASS 연동 또는 CoolSMS 등)
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER=

# NEIS API (교육부 나이스 오픈 API)
NEIS_API_KEY=

# AWS S3 (이미지 업로드)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=momstalk-media
AWS_REGION=ap-northeast-2

# App
APP_NAME=MomsTalk
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
