# 서비스 DB (auth_captures, users, reports 등)
DATABASE_URL=postgresql://momstalk:momstalk_pass@localhost:5432/momstalk_db

# AWS S3 (캡처 이미지 presigned GET URL 생성용)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=momstalk-media
AWS_REGION=ap-northeast-2

# 관리자 대시보드 비밀번호 (Streamlit Basic Auth 대용)
ADMIN_PASSWORD=change_me_before_deploy

# IP 화이트리스트 (콤마 구분, 빈 값이면 모두 허용)
ALLOWED_IPS=
